{
  "name": "dlut-gpa-calculator",
  "private": true,
  "version": "2.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config config/vite.config.ts",
    "build": "tsc -p tsconfig.json && vite build --config config/vite.config.ts",
    "preview": "vite preview --config config/vite.config.ts",
    "test": "vitest --config config/vite.config.ts",
    "test:run": "vitest run --config config/vite.config.ts",
    "test:ui": "vitest --ui --config config/vite.config.ts",
    "test:coverage": "vitest run --coverage --config config/vite.config.ts",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --ext ts,tsx --fix",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,scss,json,md}\" \"docs/**/*.md\" README.md",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,scss,json,md}\" \"docs/**/*.md\" README.md",
    "clean": "rimraf dist",
    "analyze": "npm run build -- --mode analyze"
  },
  "dependencies": {
    "framer-motion": "^12.34.3",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.460.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.12.0",
    "tesseract.js": "^7.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.0.0",
    "@types/node": "^20.11.24",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.18",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "eslint-plugin-unused-imports": "^3.1.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.35",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.2",
    "vite": "^5.1.4",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ],
  "keywords": [
    "education",
    "gpa",
    "calculator",
    "university",
    "dlut",
    "dalian-university-of-technology",
    "academic-performance",
    "student-tool"
  ],
  "author": "DLUT Student Community",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/dlut-gpa.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/dlut-gpa/issues"
  },
  "homepage": "https://github.com/your-username/dlut-gpa#readme"
}
